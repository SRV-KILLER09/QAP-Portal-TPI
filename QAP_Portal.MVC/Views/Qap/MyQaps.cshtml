@model List<QapGroupSummary>
@{
    ViewData["Title"] = "My QAPs";
    var active = ViewBag.ActiveStatus as QapStatus?;
}
<div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;font-weight: 700;letter-spacing: 0.5px;">
    QAP MANAGEMENT
</div>
<h1 class="page-title" style="margin-bottom: 20px;">My QAPs</h1>

<div class="tabs">
    <a class="@(active == null ? "active" : "")" asp-action="MyQaps">All QAPs</a>
    <a class="@(active == QapStatus.Draft ? "active" : "")" asp-action="MyQaps" asp-route-status="Draft">Draft</a>
    <a class="@(active == QapStatus.Submitted ? "active" : "")" asp-action="MyQaps" asp-route-status="Submitted">Submitted</a>
    <a class="@(active == QapStatus.Approved ? "active" : "")" asp-action="MyQaps" asp-route-status="Approved">Approved</a>
    <a class="@(active == QapStatus.Rejected ? "active" : "")" asp-action="MyQaps" asp-route-status="Rejected">Rejected</a>
</div>

<div class="card animate-fade-in" style="padding: 0; overflow: hidden; border-radius: var(--radius-lg);">
    <table class="qap-table">
        <thead>
            <tr>
                <th>QAP Number</th>
                <th>PO Number</th>
                <th style="text-align: center;">Line Items</th>
                <th>Submitted By</th>
                <th>Date</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" style="text-align:center;color:var(--text-muted);padding: 32px 18px;">
                    No QAPs found matching this status.
                </td>
            </tr>
        }
        @foreach (var qap in Model)
        {
            <tr>
                <td style="font-weight: 700; color: var(--text-main);">@qap.QapNumber</td>
                <td style="font-weight: 700; color: var(--primary);">@qap.PoNumber</td>
                <td style="text-align: center;"><span style="background-color: var(--primary-light); color: var(--primary); padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 700;">@qap.LineItems.Count</span></td>
                <td>@qap.InitiatedBy</td>
                <td>@(qap.InitiatedOn?.ToString("M/d/yyyy") ?? "-")</td>
                <td><span class="pill pill-@qap.Status.ToString().ToLower()">@qap.Status</span></td>
                <td style="text-align: right; padding-right: 24px;">
                    <a asp-action="Details" asp-route-id="@qap.GroupId" class="btn btn-secondary" style="padding: 4px 10px; font-size: 12px; box-shadow: none;">
                        View Details &gt;
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@model QapGroupDetail
@{
    ViewData["Title"] = Model.QapNumber;
}

<div style="margin-bottom: 20px;">
    <a asp-action="MyQaps" class="btn btn-secondary" style="padding: 6px 12px; font-size: 12px;">
        &lt; Back to QAPs
    </a>
</div>

<div class="card animate-fade-in" style="border-left: 4px solid var(--primary);">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px;">
        <div>
            <div style="font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;">
                Quality Assurance Plan
            </div>
            <h1 class="page-title" style="margin-bottom: 8px;">@Model.QapNumber</h1>
            <span class="pill pill-@Model.Status.ToString().ToLower()">@Model.Status</span>
        </div>
        
        <div style="display: flex; gap: 8px;">
            @if (Model.Status == QapStatus.Rejected)
            {
                <form asp-action="Reopen" asp-route-id="@Model.GroupId" method="post">
                    <button type="submit" class="btn btn-primary">Reopen for Editing</button>
                </form>
            }
            @if (Model.Status == QapStatus.Draft)
            {
                <form asp-action="Resubmit" asp-route-id="@Model.GroupId" method="post">
                    <button type="submit" class="btn btn-primary">✓ Resubmit QAP</button>
                </form>
            }
        </div>
    </div>
</div>

<div class="card animate-fade-in" style="animation-delay: 0.1s;">
    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; color: var(--text-main); border-bottom: 1.5px solid var(--border); padding-bottom: 8px;">
        Purchase Order Information
    </h3>
    <div class="detail-grid">
        <div><div class="label">PO Number</div><div class="value" style="color: var(--primary);">@Model.PoNumber</div></div>
        <div><div class="label">PO Date</div><div class="value">@(Model.PoDate?.ToString("yyyy-MM-dd") ?? "-")</div></div>
        <div><div class="label">Vendor Code</div><div class="value">@(Model.VendorCode ?? "-")</div></div>
        <div><div class="label">PO Description</div><div class="value">@(Model.PoDescription ?? "-")</div></div>
    </div>
</div>

<div class="card animate-fade-in" style="animation-delay: 0.15s;">
    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; color: var(--text-main); border-bottom: 1.5px solid var(--border); padding-bottom: 8px;">
        Line Items in this QAP (@Model.LineItems.Count)
    </h3>
    <table class="line-items-table">
        <thead>
            <tr>
                <th style="width: 80px;">Line #</th>
                <th style="width: 80px;">Item #</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var li in Model.LineItems)
            {
                <tr>
                    <td style="font-weight: 700; color: var(--text-main);">@li.Line</td>
                    <td style="font-weight: 700; color: var(--text-muted);">@li.ItemNo</td>
                    <td>@(li.Description ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card animate-fade-in" style="animation-delay: 0.2s;">
    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; color: var(--text-main); border-bottom: 1.5px solid var(--border); padding-bottom: 8px;">
        Associated Documents
    </h3>
    
    <div style="margin-bottom: 20px;">
        <div class="label" style="margin-bottom: 8px;">PO Level Documents</div>
        <div class="doc-grid">
            @if (Model.HasTechSpec)
            {
                <a class="doc-card" asp-action="DownloadTechSpec" asp-route-po="@Model.PoNumber">
                    <div class="doc-card-icon">📄</div>
                    <div class="doc-card-info">
                        <div class="doc-card-title">Technical Specification</div>
                        <div class="doc-card-subtitle">PO level document</div>
                    </div>
                </a>
            }
            @if (Model.HasPoCopy)
            {
                <a class="doc-card" asp-action="DownloadPoCopy" asp-route-po="@Model.PoNumber">
                    <div class="doc-card-icon">📄</div>
                    <div class="doc-card-info">
                        <div class="doc-card-title">Purchase Order Copy</div>
                        <div class="doc-card-subtitle">PO level document</div>
                    </div>
                </a>
            }
            @if (!Model.HasTechSpec && !Model.HasPoCopy)
            {
                <div style="font-size: 13px; color: var(--text-muted); padding: 8px 12px; background: #f8fafc; border-radius: var(--radius-sm); border: 1px dashed var(--border); width: 100%;">
                    No PO level documents uploaded
                </div>
            }
        </div>
    </div>

    <div>
        <div class="label" style="margin-bottom: 8px;">Group/Item Documents</div>
        <div class="doc-grid">
            @if (Model.HasQapDocument)
            {
                <a class="doc-card" asp-action="DownloadQapDocument" asp-route-id="@Model.GroupId">
                    <div class="doc-card-icon" style="background-color: var(--secondary-light); color: var(--secondary);">📁</div>
                    <div class="doc-card-info">
                        <div class="doc-card-title">QAP Document</div>
                        <div class="doc-card-subtitle">Group sheet upload</div>
                    </div>
                </a>
            }
            @if (Model.HasDrawing)
            {
                <a class="doc-card" asp-action="DownloadDrawing" asp-route-id="@Model.GroupId">
                    <div class="doc-card-icon" style="background-color: var(--secondary-light); color: var(--secondary);">📐</div>
                    <div class="doc-card-info">
                        <div class="doc-card-title">Drawing</div>
                        <div class="doc-card-subtitle">Technical blueprint</div>
                    </div>
                </a>
            }
            @if (!Model.HasQapDocument && !Model.HasDrawing)
            {
                <div style="font-size: 13px; color: var(--text-muted); padding: 8px 12px; background: #f8fafc; border-radius: var(--radius-sm); border: 1px dashed var(--border); width: 100%;">
                    No group documents uploaded
                </div>
            }
        </div>
    </div>
</div>

<div class="card animate-fade-in" style="animation-delay: 0.25s;">
    <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 16px; color: var(--text-main); border-bottom: 1.5px solid var(--border); padding-bottom: 8px;">
        Action &amp; Decision Logs
    </h3>
    
    <div class="timeline">
        @foreach (var log in Model.ActionLogs)
        {
            <div class="timeline-item @(log.Stage == "I" ? "initiator" : "")">
                <div class="timeline-badge">@(log.Stage == "I" ? "I" : "R")</div>
                <div class="timeline-content">
                    <div class="timeline-header">
                        <span class="timeline-user">
                            @log.ActionBy 
                            <span class="timeline-stage" style="@(log.Stage == "I" ? "background-color: var(--secondary-light); color: var(--secondary);" : "background-color: var(--primary-light); color: var(--primary);")">
                                @(log.Stage == "I" ? "Initiator" : "Reviewer")
                            </span>
                        </span>
                        <span class="timeline-date">@(log.ActionOn?.ToString("M/d/yyyy, h:mm tt") ?? "-")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(log.Remarks))
                    {
                        <div class="timeline-remarks">@log.Remarks</div>
                    }
                    else
                    {
                        <div style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">No remarks provided.</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

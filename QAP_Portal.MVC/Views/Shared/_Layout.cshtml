    <script>
        function dismissToast() {
            const toast = document.getElementById('welcomeToast');
            if (toast) {
                toast.classList.remove('animate-toast-in');
                toast.classList.add('animate-toast-out');
                setTimeout(() => toast.remove(), 400);
            }
        }

        // Toggle Notifications Menu
        function toggleNotificationsMenu() {
            const dropdown = document.getElementById('notificationsDropdown');
            if (dropdown) {
                const isHidden = dropdown.style.display === 'none';
                dropdown.style.display = isHidden ? 'block' : 'none';
                if (isHidden) {
                    // Close command palette if open
                    document.getElementById('cmdPaletteModal').style.display = 'none';
                }
            }
        }

        // Command Palette actions list
        const cmdActions = [
            { name: "Go to Dashboard", desc: "Navigate to home dashboard", url: "/Home/Dashboard", icon: `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>` },
            { name: "Create New QAP", desc: "Start a new Quality Assurance Plan wizard", url: "/Qap/Create", icon: `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>` },
            { name: "View My QAPs", desc: "List of your generated QAPs and status", url: "/Qap/MyQaps", icon: `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>` },
            { name: "Review Pending QAPs", desc: "Admin review queue for QAP approvals", url: "/QapApproval/Index", icon: `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>` },
            { name: "Helpdesk Support", desc: "Contact system administrator", url: "#support", icon: `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>` },
            { name: "Toggle Theme", desc: "Switch between dark and light modes", action: "toggleTheme", icon: `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>` },
            { name: "Logout", desc: "Log out of current portal session", action: "logout", icon: `<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>` }
        ];

        // Open Command Palette
        function openCommandPalette() {
            const modal = document.getElementById('cmdPaletteModal');
            const input = document.getElementById('cmdSearchInput');
            if (modal && input) {
                modal.style.display = 'flex';
                input.value = '';
                // Close notifications menu if open
                document.getElementById('notificationsDropdown').style.display = 'none';
                renderCommandResults("");
                setTimeout(() => input.focus(), 50);
            }
        }

        // Close Command Palette
        function closeCommandPalette(event) {
            const modal = document.getElementById('cmdPaletteModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        // Render Command Results
        function renderCommandResults(query) {
            const list = document.getElementById('cmdResultsList');
            if (!list) return;
            
            const filtered = cmdActions.filter(act => 
                act.name.toLowerCase().includes(query.toLowerCase()) || 
                act.desc.toLowerCase().includes(query.toLowerCase())
            );
            
            if (filtered.length === 0) {
                list.innerHTML = `<div style="padding: 20px 24px; text-align: center; color: #5f7596; font-size: 13.5px;">No actions or pages match your query.</div>`;
                return;
            }
            
            list.innerHTML = filtered.map(act => {
                const globalIndex = cmdActions.indexOf(act);
                return `
                    <div class="cmd-result-item" onclick="executeCommand(${globalIndex})">
                        <span class="cmd-result-icon">${act.icon}</span>
                        <div class="cmd-result-info">
                            <span class="cmd-result-name">${act.name}</span>
                            <span class="cmd-result-desc">${act.desc}</span>
                        </div>
                        <span class="cmd-select-badge">Select</span>
                    </div>
                `;
            }).join('');
        }

        // Execute Command Action
        function executeCommand(index) {
            const act = cmdActions[index];
            if (!act) return;
            
            closeCommandPalette();
            
            if (act.url) {
                window.location.href = act.url;
            } else if (act.action === "toggleTheme") {
                const toggleBtn = document.getElementById('themeToggleBtn');
                if (toggleBtn) toggleBtn.click();
            } else if (act.action === "logout") {
                const logoutForm = document.querySelector('form[action$="Logout"]');
                if (logoutForm) logoutForm.submit();
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Dismiss welcome toast
            const toast = document.getElementById('welcomeToast');
            if (toast) {
                setTimeout(dismissToast, 6000);
            }

            // Bind inputs and hotkeys
            const input = document.getElementById('cmdSearchInput');
            if (input) {
                input.addEventListener('input', (e) => renderCommandResults(e.target.value));
                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        const firstItem = document.querySelector('#cmdResultsList .cmd-result-item');
                        if (firstItem) firstItem.click();
                    }
                });
            }

            // Global Ctrl+K hotkey
            window.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
                    e.preventDefault();
                    openCommandPalette();
                }
                if (e.key === 'Escape') {
                    closeCommandPalette();
                    document.getElementById('notificationsDropdown').style.display = 'none';
                }
            });

            const toggleBtn = document.getElementById('themeToggleBtn');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    const isDark = document.body.classList.toggle('dark-theme');
                    document.documentElement.classList.toggle('dark-theme', isDark);
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                });
            }
        });
    </script>

    <!-- Real-time Alert Toast Container -->
    <div id="liveAlertToast" class="live-alert-toast" style="display: none; position: fixed; top: 24px; right: 24px; width: 340px; background-color: #05080e; border: 1.5px solid #ef4444; border-radius: var(--radius-md); box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(239, 68, 68, 0.2); z-index: 100005; padding: 16px; overflow: hidden;">
        <div style="display: flex; align-items: flex-start; gap: 12px;">
            <div style="width: 24px; height: 24px; border-radius: 50%; background-color: rgba(239, 68, 68, 0.1); color: #ef4444; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; flex-shrink: 0;">!</div>
            <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                <span id="liveAlertTitle" style="font-size: 12px; font-weight: 800; color: #ef4444; letter-spacing: 0.5px; text-transform: uppercase;">System Warning</span>
                <span id="liveAlertMsg" style="font-size: 11px; color: #e2e8f0; line-height: 1.4;"></span>
                <span id="liveAlertTime" style="font-size: 8.5px; color: #5f7596; font-family: monospace;"></span>
            </div>
            <button onclick="closeLiveAlert()" style="background: none; border: none; color: #5f7596; font-size: 18px; cursor: pointer; line-height: 1; padding: 0; margin-left: 8px;">&times;</button>
        </div>
    </div>

    <!-- General Purpose Toast Container -->
    <div id="generalActionToast" class="live-alert-toast" style="display: none; position: fixed; bottom: 24px; right: 24px; width: 320px; background-color: #05080e; border: 1.5px solid #3b82f6; border-radius: var(--radius-md); box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(59, 130, 246, 0.2); z-index: 100005; padding: 14px 16px; overflow: hidden;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <div style="width: 24px; height: 24px; border-radius: 50%; background-color: rgba(59, 130, 246, 0.1); color: #3b82f6; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: bold; flex-shrink: 0;">✓</div>
            <div style="flex: 1; display: flex; flex-direction: column; gap: 2px;">
                <span id="generalToastTitle" style="font-size: 12px; font-weight: 800; color: #3b82f6; letter-spacing: 0.5px; text-transform: uppercase;">Sync Successful</span>
                <span id="generalToastMsg" style="font-size: 11px; color: #e2e8f0; line-height: 1.3;"></span>
            </div>
            <button onclick="document.getElementById('generalActionToast').style.display='none'" style="background: none; border: none; color: #5f7596; font-size: 18px; cursor: pointer; line-height: 1; padding: 0; margin-left: 8px;">&times;</button>
        </div>
    </div>


    <!-- SignalR Client Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <script>
        // Connect to SignalR NotificationHub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (title, message, timestamp) {
            console.log("Announcement received:", title, message, timestamp);
            
            // 1. Increment sidebar notifications count
            const badge = document.querySelector('#sidebarNotificationsBtn .capsule-badge');
            if (badge) {
                const current = parseInt(badge.textContent) || 0;
                badge.textContent = current + 1;
            }

            // 2. Prepend message item inside dropdown menu
            const dropdownList = document.querySelector('#notificationsDropdown div:nth-child(2)');
            if (dropdownList) {
                const newItem = document.createElement('div');
                newItem.className = 'notification-item';
                newItem.style.padding = '12px 16px';
                newItem.style.borderBottom = '1px solid rgba(255, 255, 255, 0.02)';
                newItem.style.display = 'flex';
                newItem.style.flexDirection = 'column';
                newItem.style.gap = '4px';
                newItem.innerHTML = `
                    <div style="font-size: 11.5px; font-weight: 700; color: #ff5e5e;">ALERT: ${title}</div>
                    <div style="font-size: 10px; color: #e2e8f0; line-height: 1.4;">${message}</div>
                    <div style="font-size: 9px; color: #5f7596;">Broadcast by Admin &middot; Just now</div>
                `;
                dropdownList.insertBefore(newItem, dropdownList.firstChild);
            }

            // 3. Slide in real-time alert toast
            const toast = document.getElementById('liveAlertToast');
            const tTitle = document.getElementById('liveAlertTitle');
            const tMsg = document.getElementById('liveAlertMsg');
            const tTime = document.getElementById('liveAlertTime');
            if (toast && tTitle && tMsg && tTime) {
                tTitle.textContent = title;
                tMsg.textContent = message;
                tTime.textContent = timestamp;
                
                toast.style.display = 'block';
                toast.style.animation = 'alertSlideIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards';
                
                // Auto close after 10 seconds
                setTimeout(closeLiveAlert, 10000);
            }
        });

        connection.start().then(function () {
            console.log("SignalR Connected to NotificationHub");
        }).catch(function (err) {
            console.error("SignalR Connection Error: ", err.toString());
        });

        function closeLiveAlert() {
            const toast = document.getElementById('liveAlertToast');
            if (toast && toast.style.display !== 'none') {
                toast.style.animation = 'alertSlideOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards';
                setTimeout(() => {
                    toast.style.display = 'none';
                }, 300);
            }
        }

        function toggleMobileSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.querySelector('.sidebar-overlay');
            if (sidebar && overlay) {
                sidebar.classList.add('sidebar-open');
                overlay.classList.add('active');
            }
        }

        function closeMobileSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.querySelector('.sidebar-overlay');
            if (sidebar && overlay) {
                sidebar.classList.remove('sidebar-open');
                overlay.classList.remove('active');
            }
        }

        // Interactive User Profile Dropdown
        function toggleProfileDropdown(e) {
            e.stopPropagation();
            const dropdown = document.getElementById('profileDropdown');
            if (dropdown) {
                const isHidden = dropdown.style.display === 'none';
                dropdown.style.display = isHidden ? 'block' : 'none';
            }
        }

        function closeProfileDropdown() {
            const dropdown = document.getElementById('profileDropdown');
            if (dropdown) {
                dropdown.style.display = 'none';
            }
        }

        // Click outside handlers
        document.addEventListener('click', function(e) {
            closeProfileDropdown();
            // Also close notifications dropdown if clicked outside
            const notifDropdown = document.getElementById('notificationsDropdown');
            const notifBtn = document.getElementById('sidebarNotificationsBtn');
            if (notifDropdown && !notifDropdown.contains(e.target) && notifBtn && !notifBtn.contains(e.target)) {
                notifDropdown.style.display = 'none';
            }
        });

        // Interactive Helpdesk Modal
        function openHelpdeskModal() {
            const modal = document.getElementById('helpdeskModal');
            if (modal) {
                modal.style.display = 'flex';
                document.getElementById('helpdeskForm').style.display = 'block';
                document.getElementById('helpdeskSuccess').style.display = 'none';
                document.getElementById('helpdeskMessage').value = '';
            }
        }

        function closeHelpdeskModal(e) {
            if (e && e.target !== document.getElementById('helpdeskModal')) return;
            const modal = document.getElementById('helpdeskModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        function submitHelpdeskTicket(e) {
            e.preventDefault();
            const cat = document.getElementById('helpdeskCategory').value;
            const msg = document.getElementById('helpdeskMessage').value;
            
            // Generate a random ticket ID
            const tktId = `GAIL-TKT-${new Date().getFullYear()}-${Math.floor(1000 + Math.random() * 9000)}`;
            
            document.getElementById('helpdeskTicketId').textContent = `Ticket ID: ${tktId}`;
            document.getElementById('helpdeskForm').style.display = 'none';
            document.getElementById('helpdeskSuccess').style.display = 'block';
        }

        // Change Password Modal Helpers
        function openChangePasswordModal() {
            const modal = document.getElementById('changePasswordModal');
            if (modal) {
                modal.style.display = 'flex';
                document.getElementById('changePasswordForm').style.display = 'flex';
                document.getElementById('changePasswordSuccess').style.display = 'none';
                document.getElementById('changePasswordError').style.display = 'none';
                document.getElementById('currentPasswordInput').value = '';
                document.getElementById('newPasswordInput').value = '';
                document.getElementById('confirmNewPasswordInput').value = '';
                setTimeout(() => document.getElementById('currentPasswordInput').focus(), 50);
            }
        }

        function closeChangePasswordModal(e) {
            if (e && e.target !== document.getElementById('changePasswordModal') && e.target.className !== 'modal-close-btn') return;
            const modal = document.getElementById('changePasswordModal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        function submitChangePassword(e) {
            e.preventDefault();
            const currentPass = document.getElementById('currentPasswordInput').value;
            const newPass = document.getElementById('newPasswordInput').value;
            const confirmPass = document.getElementById('confirmNewPasswordInput').value;
            const errorEl = document.getElementById('changePasswordError');
            
            if (newPass !== confirmPass) {
                errorEl.textContent = "New password and confirmation password do not match.";
                errorEl.style.display = "block";
                return;
            }

            errorEl.style.display = "none";
            
            fetch('/Home/ChangePassword', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `currentPassword=${encodeURIComponent(currentPass)}&newPassword=${encodeURIComponent(newPass)}`
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('changePasswordForm').style.display = 'none';
                    document.getElementById('changePasswordSuccess').style.display = 'block';
                } else {
                    errorEl.textContent = data.message || "Failed to update password.";
                    errorEl.style.display = "block";
                }
            })
            .catch(err => {
                console.error(err);
                errorEl.textContent = "An error occurred while updating the password.";
                errorEl.style.display = "block";
            });
        }

        // Document Live Preview Helpers
        function openDocumentPreview(fileOrUrl, title, sub) {
            const modal = document.getElementById('docPreviewModal');
            const titleEl = document.getElementById('previewTitle');
            const subEl = document.getElementById('previewSub');
            const container = document.getElementById('previewContentContainer');
            
            if (!modal || !container) return;

            titleEl.textContent = title || "Document Preview";
            subEl.textContent = sub || "Inline Viewer";
            container.innerHTML = '<div style="color: #5f7596; font-size: 13px; font-family: sans-serif; font-weight: 600; display: flex; align-items: center; gap: 8px; justify-content: center; height: 100%;"><div class="health-pulse-dot" style="background-color: #3b82f6;"></div>Loading document stream...</div>';

            modal.style.display = 'flex';

            let url = "";
            let isDocxOrUnsupported = false;
            let fileType = "";

            if (typeof fileOrUrl === 'string') {
                url = fileOrUrl;
                const ext = url.split('?')[0].split('.').pop().toLowerCase();
                if (['jpg', 'jpeg', 'png', 'gif', 'svg'].includes(ext)) {
                    fileType = "image";
                } else if (ext === 'pdf') {
                    fileType = "pdf";
                } else if (['docx', 'doc', 'xls', 'xlsx', 'ppt', 'pptx'].includes(ext)) {
                    isDocxOrUnsupported = true;
                    fileType = ext;
                } else {
                    fileType = "pdf"; // Default to iframe preview
                }
            } else if (fileOrUrl instanceof File) {
                url = URL.createObjectURL(fileOrUrl);
                const type = fileOrUrl.type.toLowerCase();
                if (type.startsWith('image/')) {
                    fileType = "image";
                } else if (type === 'application/pdf') {
                    fileType = "pdf";
                } else {
                    const ext = fileOrUrl.name.split('.').pop().toLowerCase();
                    if (['docx', 'doc', 'xls', 'xlsx', 'ppt', 'pptx'].includes(ext)) {
                        isDocxOrUnsupported = true;
                        fileType = ext;
                    } else {
                        fileType = "pdf";
                    }
                }
            } else {
                container.innerHTML = '<div style="color: #ef4444; font-size: 13px; font-weight: 600; display: flex; align-items: center; justify-content: center; height: 100%;">No file uploaded or file reference is invalid.</div>';
                return;
            }

            modal.dataset.tempUrl = (fileOrUrl instanceof File) ? url : "";

            const downloadBtn = document.getElementById('modalDownloadBtn');
            if (downloadBtn) {
                downloadBtn.href = url;
                downloadBtn.download = (fileOrUrl instanceof File) ? fileOrUrl.name : (title || 'document');
                downloadBtn.style.display = 'inline-flex';
            }

            setTimeout(() => {
                if (isDocxOrUnsupported) {
                    container.innerHTML = `
                        <div style="text-align: center; padding: 40px; color: var(--text-muted); font-family: 'Inter', sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" style="width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.85;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                            <h4 style="color: #ffffff; font-weight: 700; margin-bottom: 8px; font-size: 15px;">Preview Not Supported</h4>
                            <p style="font-size: 12.5px; line-height: 1.4; max-width: 320px; margin: 0 auto 18px auto; text-align: center;">
                                Microsoft Office files (.${fileType}) cannot be rendered directly in the browser preview.
                            </p>
                            <a href="${url}" download="${fileOrUrl instanceof File ? fileOrUrl.name : 'download'}" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 8px; font-size: 12.5px; padding: 8px 16px; text-decoration: none; border-radius: 6px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:14px;height:14px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                Download Document
                            </a>
                        </div>`;
                } else if (fileType === 'image') {
                    container.innerHTML = `<img src="${url}" style="max-width: 95%; max-height: 95%; object-fit: contain; box-shadow: 0 10px 30px rgba(0,0,0,0.5); border-radius: 6px; border: 1px solid rgba(255,255,255,0.1);" />`;
                } else {
                    container.innerHTML = `<iframe src="${url}" style="width: 100%; height: 100%; border: none;" />`;
                }
            }, 300);
        }

        function closeDocumentPreview(e) {
            if (e && e.target !== document.getElementById('docPreviewModal') && e.target.className !== 'modal-close-btn') return;
            const modal = document.getElementById('docPreviewModal');
            const container = document.getElementById('previewContentContainer');
            const downloadBtn = document.getElementById('modalDownloadBtn');
            
            if (downloadBtn) {
                downloadBtn.href = "";
                downloadBtn.style.display = 'none';
            }
            if (modal) {
                modal.style.display = 'none';
                if (modal.dataset.tempUrl) {
                    URL.revokeObjectURL(modal.dataset.tempUrl);
                    modal.dataset.tempUrl = "";
                }
                if (container) container.innerHTML = '';
            }
        }

        function showActionToast(title, message) {
            const toast = document.getElementById('generalActionToast');
            const titleEl = document.getElementById('generalToastTitle');
            const msgEl = document.getElementById('generalToastMsg');
            if (toast && titleEl && msgEl) {
                titleEl.textContent = title;
                msgEl.textContent = message;
                toast.style.display = 'block';
                toast.style.animation = 'alertSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards';
                
                // Clear any existing timeout on the toast
                if (toast.dataset.timeoutId) {
                    clearTimeout(Number(toast.dataset.timeoutId));
                }
                
                const tId = setTimeout(() => {
                    if (toast.style.display !== 'none') {
                        toast.style.animation = 'alertSlideOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards';
                        setTimeout(() => { toast.style.display = 'none'; }, 300);
                    }
                }, 4000);
                toast.dataset.timeoutId = String(tId);
            }
        }

        // Bind all support triggers dynamically
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('a[href="#support"]').forEach(a => {
                a.addEventListener('click', function(e) {
                    e.preventDefault();
                    openHelpdeskModal();
                });
            });
        });
    </script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
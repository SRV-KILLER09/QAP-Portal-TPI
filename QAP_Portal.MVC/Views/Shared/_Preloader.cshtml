@*
    Interactive and Responsive Preloader
    Features:
    - Dark background with subtle grid pattern
    - Circular logo with "GAIL" and "DIGITALIZED NGMC" text
    - Circular progress indicator around the logo
    - Linear progress bar with dynamic text and percentage
    - Fully responsive design
*@

<div id="preloader" class="preloader">
    <div class="preloader-content">
        <!-- Logo Section -->
        <div class="logo-container">
            <div class="circular-progress">
                <!-- Decorative rotating ring -->
                <div class="outer-decor-ring"></div>
                <svg class="progress-ring" viewBox="0 0 120 120">
                    <circle class="progress-ring-bg" cx="60" cy="60" r="54" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="4"/>
                    <circle class="progress-ring-circle" cx="60" cy="60" r="54" fill="none" stroke="url(#gradient)" stroke-width="4" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="339.292"/>
                    <defs>
                        <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#3b82f6"/>
                            <stop offset="50%" stop-color="#1d4ed8"/>
                            <stop offset="100%" stop-color="#1e3a8a"/>
                        </linearGradient>
                    </defs>
                </svg>
                <div class="logo-inner">
                    <img src="/images/gail_logo.png" alt="GAIL Logo" class="gail-logo" />
                </div>
            </div>
        </div>
        
        <div class="brand-text-container" style="margin-top: -12px; margin-bottom: 40px;">
            <h2 class="preloader-title" style="font-size: 24px; font-weight: 800; color: #ffffff; letter-spacing: 6px; margin: 0 0 6px 0; text-transform: uppercase; font-family: 'Outfit', sans-serif;">GAIL (India) Limited</h2>
            <div class="logo-subtext" style="font-size: 9.5px; font-weight: 700; color: #3b82f6; letter-spacing: 3.5px; text-transform: uppercase; font-family: 'Inter', sans-serif;">QAP &amp; TPI Portal</div>
        </div>

        <!-- Progress Bar Section -->
        <div class="progress-section">
            <div class="progress-text" id="progressText">AUTHENTICATING TRANSMISSION GRID...</div>
            <div class="progress-bar-container">
                <div class="progress-bar" id="progressBar">
                    <div class="progress-bar-fill" id="progressBarFill"></div>
                    <div class="progress-bar-glow"></div>
                </div>
                <div class="progress-percentage" id="progressPercentage">0%</div>
            </div>
        </div>
    </div>
</div>

<text>
<style>
    .preloader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(3, 5, 8, 0.88);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 1;
        transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
    }

    .preloader.hidden {
        opacity: 0;
        visibility: hidden;
    }

    /* Grid Pattern Background */
    .preloader::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: 
            linear-gradient(rgba(59, 130, 246, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(59, 130, 246, 0.05) 1px, transparent 1px);
        background-size: 50px 50px;
        animation: gridMove 20s linear infinite;
    }

    @@keyframes gridMove {
        0% { transform: translate(0, 0); }
        100% { transform: translate(50px, 50px); }
    }

    .preloader-content {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 20px;
    }

    /* Logo Container */
    .logo-container {
        margin-bottom: 30px;
    }

    .circular-progress {
        position: relative;
        width: 140px;
        height: 140px;
        margin: 0 auto;
    }

    .outer-decor-ring {
        position: absolute;
        top: -8px;
        left: -8px;
        width: 156px;
        height: 156px;
        border: 1.5px dashed rgba(59, 130, 246, 0.2);
        border-radius: 50%;
        animation: rotateOrbit 15s linear infinite;
        pointer-events: none;
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.03);
    }

    @@keyframes rotateOrbit {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .progress-ring {
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: rotate(-90deg) scale(1); }
        50% { opacity: 0.9; transform: rotate(-90deg) scale(0.98); }
    }

    .progress-ring-circle {
        transition: stroke-dashoffset 0.3s ease;
        filter: drop-shadow(0 0 12px rgba(59, 130, 246, 0.6));
    }

    .logo-inner {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-inner::after {
        content: '';
        position: absolute;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.22) 0%, transparent 70%);
        z-index: -1;
        animation: radialPulse 3s ease-in-out infinite alternate;
        pointer-events: none;
    }

    @@keyframes radialPulse {
        0% { transform: scale(0.9); opacity: 0.4; }
        100% { transform: scale(1.15); opacity: 1; }
    }

    .gail-logo {
        width: 76px;
        height: auto;
        filter: drop-shadow(0 0 12px rgba(59, 130, 246, 0.4));
        animation: logoGlow 3s ease-in-out infinite;
        z-index: 2;
    }

    @@keyframes logoGlow {
        0%, 100% { filter: drop-shadow(0 0 12px rgba(59, 130, 246, 0.4)) scale(1); }
        50% { filter: drop-shadow(0 0 22px rgba(59, 130, 246, 0.75)) scale(1.02); }
    }

    /* Progress Section */
    .progress-section {
        max-width: 320px;
        margin: 0 auto;
    }

    .progress-text {
        font-size: 11px;
        font-weight: 600;
        color: #94a3b8;
        letter-spacing: 1.5px;
        margin-bottom: 12px;
        text-transform: uppercase;
        animation: textGlow 2s ease-in-out infinite;
    }

    @@keyframes textGlow {
        0%, 100% { opacity: 0.8; }
        50% { opacity: 1; text-shadow: 0 0 8px rgba(59, 130, 246, 0.4); }
    }

    .progress-bar-container {
        position: relative;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .progress-bar {
        flex: 1;
        height: 3px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 1.5px;
        overflow: hidden;
        position: relative;
    }

    .progress-bar-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #1e40af, #3b82f6, #60a5fa);
        border-radius: 1.5px;
        transition: width 0.3s ease;
        position: relative;
        box-shadow: 0 0 12px rgba(59, 130, 246, 0.4);
    }

    .progress-bar-glow {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 100%;
        background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.4), transparent);
        animation: shimmer 2s infinite;
    }

    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    .progress-percentage {
        font-size: 13.5px;
        font-weight: 700;
        color: #60a5fa;
        min-width: 40px;
        text-align: right;
        text-shadow: 0 0 10px rgba(59, 130, 246, 0.4);
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .circular-progress {
            width: 140px;
            height: 140px;
        }

        .gail-logo {
            width: 76px;
        }

        .logo-subtext {
            font-size: 10px;
            letter-spacing: 2px;
        }

        .progress-text {
            font-size: 11px;
            letter-spacing: 1px;
        }

        .progress-percentage {
            font-size: 14px;
        }
    }

    @@media (max-width: 480px) {
        .gail-logo {
            width: 76px;
        }

        .circular-progress {
            width: 140px;
            height: 140px;
        }

        .logo-subtext {
            font-size: 9px;
        }

        .progress-bar-container {
            flex-direction: row;
            align-items: center;
            gap: 12px;
        }

        .progress-percentage {
            text-align: right;
        }
    }
</style>
</text>

<script>
    (function() {
        const preloader = document.getElementById('preloader');
        const progressCircle = document.querySelector('.progress-ring-circle');
        const progressBarFill = document.getElementById('progressBarFill');
        const progressPercentage = document.getElementById('progressPercentage');
        const progressText = document.getElementById('progressText');
        
        const circumference = 2 * Math.PI * 54; // r = 54
        const messages = [
            'AUTHENTICATING TRANSMISSION GRID...',
            'ESTABLISHING SECURE CONNECTION...',
            'LOADING DIGITAL ASSETS...',
            'SYNCHRONIZING DATA STREAMS...',
            'INITIALIZING INTERFACE...',
            'PREPARING SYSTEM...'
        ];

        let progress = 0;
        let messageIndex = 0;

        function setProgress(percent) {
            const offset = circumference - (percent / 100) * circumference;
            progressCircle.style.strokeDashoffset = offset;
            progressBarFill.style.width = percent + '%';
            progressPercentage.textContent = Math.round(percent) + '%';
        }

        function updateMessage() {
            if (progress >= (messageIndex + 1) * (100 / messages.length)) {
                messageIndex = Math.min(messageIndex + 1, messages.length - 1);
                progressText.textContent = messages[messageIndex];
            }
        }

        function animate() {
            if (progress < 100) {
                // Random increment for realistic loading feel
                const increment = Math.random() * 2 + 0.5;
                progress = Math.min(progress + increment, 100);
                
                setProgress(progress);
                updateMessage();
                
                // Vary the speed for more realistic effect
                const delay = Math.random() * 50 + 30;
                setTimeout(animate, delay);
            } else {
                // Hide preloader after completion
                setTimeout(() => {
                    preloader.classList.add('hidden');
                    // Remove from DOM after transition
                    setTimeout(() => {
                        preloader.style.display = 'none';
                    }, 500);
                }, 500);
            }
        }

        // Start animation when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', animate);
        } else {
            animate();
        }

        // Expose function to manually control preloader if needed
        window.preloaderControl = {
            hide: function() {
                preloader.classList.add('hidden');
                setTimeout(() => {
                    preloader.style.display = 'none';
                }, 500);
            },
            setProgress: setProgress,
            reset: function() {
                progress = 0;
                messageIndex = 0;
                setProgress(0);
                progressText.textContent = messages[0];
                preloader.classList.remove('hidden');
                preloader.style.display = 'flex';
                animate();
            }
        };
    })();
</script>

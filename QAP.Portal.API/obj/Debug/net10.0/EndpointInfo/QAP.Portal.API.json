  "components": {
    "schemas": {
      "ActionRequest": {
        "type": "object",
        "properties": {
          "actionBy": {
            "type": "string"
          }
        }
      },
      "CreateQapRequest": {
        "type": "object",
        "properties": {
          "po": {
            "type": "string"
          },
          "initiatorEmail": {
            "type": [
              "null",
              "string"
            ]
          },
          "groups": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QapGroupRequest"
            }
          }
        }
      },
      "GroupActionLog": {
        "type": "object",
        "properties": {
          "seqNo": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "groupId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "stage": {
            "maxLength": 1,
            "type": [
              "null",
              "string"
            ]
          },
          "actionOn": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "actionBy": {
            "maxLength": 50,
            "type": [
              "null",
              "string"
            ]
          },
          "remarks": {
            "maxLength": 200,
            "type": [
              "null",
              "string"
            ]
          },
          "qapLineGroup": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/QapLineGroup"
              }
            ]
          }
        }
      },
      "IFormFile": {
        "type": "string",
        "format": "binary"
      },
      "LineItemRequest": {
        "type": "object",
        "properties": {
          "line": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "itemNo": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "PoDocument": {
        "type": "object",
        "properties": {
          "po": {
            "maxLength": 10,
            "type": "string"
          },
          "techSpec": {
            "type": [
              "null",
